      "tags": ["empty"]
    },
    {
      "name": "blank does not equal empty",
      "template": "{% if blank == empty %}TRUE{% else %}FALSE{% endif %}",
      "data": {},
      "result": "FALSE",
      "tags": ["blank", "empty", "if tag"]
    },
    {
      "name": "empty does not equal blank",
